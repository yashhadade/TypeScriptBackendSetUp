## MongoDB Connection URL
MONGO_CONNECTION_URL = mongodb://127.0.0.1:27017/tokenCustodian?replicaSet=rs0
REDIS_HOST=redis://127.0.0.1:6379
REDIS_PORT=6379

## Port
PORT = 3000

## JWT Secret
JWT_SECRET = your-secret-key

## AWS
AWS_ID = your-aws-id
AWS_SECRET = your-aws-secret
AWS_S3_REGION = your-aws-s3-region
AWS_BUCKET = your-aws-bucket
AWS_CDN_DOMAIN_LINK = your-aws-cdn-domain-link

## Encryption key for sensitive data (32+ chars or 64-char hex for AES-256)
ENCRYPTION_KEY = your-32-char-or-longer-secret-key

## EMUDRA (E-SIGN)
EMUDRA_API = your-emudra-api
EMUDRA_CLIENT_ID = your-emudra-client-id
EMUDRA_KEY_ID = your-emudra-key-id
EMUDRA_ACCESS_KEY_HASH = your-emudra-access-key-hash